#!/usr/bin/env bash
# Pre-commit hook — fast gate: lint only (ESLint + Stylelint).
# Full test suite runs on pre-push to keep commits snappy.
# Bypass: git commit --no-verify

set -e

echo "╭— RadiProtocol pre-commit gate ———————————————————————————————————————————————————————"

STAGED_TS=$(git diff --cached --name-only --diff-filter=ACM | grep '\.ts$' || true)
STAGED_CSS=$(git diff --cached --name-only --diff-filter=ACM | grep '\.css$' || true)

if [ -z "$STAGED_TS" ] && [ -z "$STAGED_CSS" ]; then
  echo "│ No staged *.ts / *.css files — skipping."
  echo "╰—————————————————————————————————————————————————————————————————————————————————————"
  exit 0
fi

if [ -n "$STAGED_TS" ]; then
  echo "│ Running eslint on staged files…"
  npx eslint $STAGED_TS
  echo "│ ✓ ESLint passed"
fi

if [ -n "$STAGED_CSS" ]; then
  echo "│ Running stylelint on staged CSS files…"
  npx stylelint $STAGED_CSS
  echo "│ ✓ Stylelint passed"
fi

# Fast affected-test gate (vitest --changed) — runs only tests impacted by
# staged files. Full suite is enforced by pre-push.
echo "│ Running affected tests (vitest --changed)…"
npx vitest run --changed

echo "│ ✓ Affected tests passed"
echo "╰—————————————————————————————————————————————————————————————————————————————————————"