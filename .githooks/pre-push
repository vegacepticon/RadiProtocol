#!/usr/bin/env bash
# Pre-push hook — full local check gate.
# Blocks push if build, lint, or tests fail.
# Bypass: git push --no-verify

set -e

echo "╭─ RadiProtocol pre-push gate ────────────────────────────────────────────"

echo "│ Running full local check…"
npm run check

echo "│ ✓ Check passed"
echo "╰────────────────────────────────────────────────────────────────────────"
